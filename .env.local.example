# SYDLE ONE — Configurações
# Org do SYDLE (ex: dgt-consultoria-dev ou dgt-consultoria)
SYDLE_ORG=dgt-consultoria-dev

# Identificador da aplicação no SYDLE (criar como "dgtPredict" no painel)
SYDLE_APP=dgtPredict

# Identificador do pacote onde estão as classes (paises, results, guesses)
SYDLE_PACKAGE=predict2026

# Logins dos administradores separados por vírgula
ADMIN_LOGINS=admin@dgt.com

# Chave secreta para o NextAuth (gerar com: openssl rand -base64 32)
NEXTAUTH_SECRET=substitua_por_uma_chave_secreta_forte
NEXTAUTH_URL=http://localhost:3000
